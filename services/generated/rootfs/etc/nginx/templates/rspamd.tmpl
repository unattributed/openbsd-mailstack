# Rspamd web UI reverse proxy
location /rspamd/ {
    proxy_pass http://10.44.0.1:11334/;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    # Optional: restrict access to WireGuard subnet only
    allow 10.44.0.0/24;
    deny all;

    # Optional: increase buffer size for UI
    proxy_buffering off;
    proxy_read_timeout 300;
}
