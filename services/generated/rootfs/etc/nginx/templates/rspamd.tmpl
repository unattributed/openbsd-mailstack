-r -- # Rspamd web UI reverse proxy
-r -- location /rspamd/ {
-r --     proxy_pass http://10.44.0.1:11334/;
-r --     proxy_http_version 1.1;
-r -- 
-r --     proxy_set_header Host $host;
-r --     proxy_set_header X-Real-IP $remote_addr;
-r --     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
-r -- 
-r --     # Optional: restrict access to WireGuard subnet only
-r --     allow 10.44.0.0/24;
-r --     deny all;
-r -- 
-r --     # Optional: increase buffer size for UI
-r --     proxy_buffering off;
-r --     proxy_read_timeout 300;
-r -- }
