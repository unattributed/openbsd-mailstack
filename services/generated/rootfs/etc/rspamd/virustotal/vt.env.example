# /root/.config/virustotal/vt.env
# VirusTotal public API configuration for Rspamd antivirus module
# Target platform: OpenBSD mail host with Rspamd
#
# Permissions:
#   owner: root
#   mode: 0600
#
# Note about usage:
#   VirusTotal public API is for non commercial or academic use and is limited
#   to 4 requests per minute, with daily and monthly quotas. It must not be
#   used in commercial products or services, nor in business workflows that do
#   not contribute new files. See VirusTotal public vs private API docs.

# your VT API key from https://www.virustotal.com/gui/my-apikey
# do not quote this unless the key itself contains special characters
VT_API_KEY=""

# enable or disable the VirusTotal scanner without deleting config
# 1 enables the scanner in Rspamd, 0 disables it
VT_SCAN_ENABLED=1

# thresholds matching Rspamd antivirus "virustotal" options
# see official Rspamd antivirus module documentation
VT_MINIMUM_ENGINES=3      # minimum engines required to consider a detection
VT_LOW_CATEGORY=5         # upper bound for low category
VT_MEDIUM_CATEGORY=10     # upper bound for medium category

# scoring used in the generated antivirus.conf
VT_SCORE_CLEAN=-0.5
VT_SCORE_LOW=2.0
VT_SCORE_MEDIUM=5.0
VT_SCORE_HIGH=8.0

# optional attachment size limit in bytes for VT scanning
# set to 0 to leave unbounded (not recommended in high volume systems)
VT_MAX_SIZE_BYTES=20000000

# VirusTotal public API quotas, for reference only
# Rspamd uses Redis caching internally to avoid unnecessary lookups,
# but you must still be mindful of quotas.
VT_PUBLIC_MAX_REQUESTS_PER_MINUTE=4
VT_PUBLIC_MAX_REQUESTS_PER_DAY=500
VT_PUBLIC_MAX_REQUESTS_PER_MONTH=15500
