# PHASE-06C: Rspamd controller worker for WireGuard-only web UI
# Pattern derived from official Rspamd docs:
#   /etc/rspamd/local.d/worker-controller.inc
#   password = "$2$your_generated_hash_here";
#   bind_socket = "localhost:11334";

# Bind controller to WireGuard interface only
bind_socket = "10.44.0.1:11334";

# Restrict access to wg subnet only
secure_ip = "10.44.0.0/24";

# Password hash is host-unique and generated by phase-06-apply.ksh.
# Placeholder must be replaced during deployment.
password = "__generate_with_rspamadm_pw__";

# Optional: enable_password only needed for dangerous ops; omit for safety.
# enable_password = "$2$separate_enable_password_hash";
