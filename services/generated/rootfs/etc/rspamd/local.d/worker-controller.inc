-r -- # PHASE-06C: Rspamd controller worker for WireGuard-only web UI
-r -- # Pattern derived from official Rspamd docs:
-r -- #   /etc/rspamd/local.d/worker-controller.inc
-r -- #   password = "$2$your_generated_hash_here";
-r -- #   bind_socket = "localhost:11334";
-r -- 
-r -- # Bind controller to WireGuard interface only
-r -- bind_socket = "10.44.0.1:11334";
-r -- 
-r -- # Restrict access to wg subnet only
-r -- secure_ip = "10.44.0.0/24";
-r -- 
-r -- # Password hash is host-unique and generated by phase-06-apply.ksh.
-r -- # Placeholder must be replaced during deployment.
-r -- password = "__generate_with_rspamadm_pw__";
-r -- 
-r -- # Optional: enable_password only needed for dangerous ops; omit for safety.
-r -- # enable_password = "$2$separate_enable_password_hash";
