-r -- # PHASE-06C: Rspamd proxy worker for Postfix milter integration
-r -- # Authoritative pattern based on Rspamd worker docs:
-r -- #   worker "rspamd_proxy" { bind_socket = "localhost:11332"; upstream "local" { default = yes; hosts = "127.0.0.1:11333"; } }
-r -- # This file is included as worker-proxy.inc, the worker wrapper is implicit.
-r -- 
-r -- # Enable milter mode so Postfix can talk to Rspamd via smtpd_milters
-r -- milter = yes;
-r -- 
-r -- # Conservative timeout for SMTP sessions through the milter
-r -- timeout = 120s;
-r -- 
-r -- # Listen for Postfix milter connections on localhost:11332
-r -- bind_socket = "127.0.0.1:11332";
-r -- 
-r -- # Forward scans to the normal worker on 127.0.0.1:11333
-r -- upstream "local" {
-r --   default = yes;
-r --   self_scan = yes;  # small single host setup, proxy does the scan directly
-r --   hosts = "127.0.0.1:11333";
-r -- }
