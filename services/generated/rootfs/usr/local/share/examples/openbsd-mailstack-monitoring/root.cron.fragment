# openbsd-mailstack monitoring and reporting cron fragment
*/5 * * * * /usr/local/sbin/openbsd-mailstack-monitoring-run >> /var/log/openbsd-mailstack-monitor.log 2>&1
15 6 * * * MAIL_TO=ops@example.com MAIL_SUBJECT_PREFIX="[openbsd-mailstack monitoring]" /usr/local/sbin/openbsd-mailstack-cron-html-report --label monitor-daily -- /usr/local/sbin/openbsd-mailstack-mail-health-report --stdout >> /var/log/openbsd-mailstack-cron-report.log 2>&1
