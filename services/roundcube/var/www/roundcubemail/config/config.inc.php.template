<?php
/* Local configuration for Roundcube Webmail */

$config = array();

/*
 +-----------------------------------------------------------------------+
 | IMAP                                                                  |
 +-----------------------------------------------------------------------+
 |
 | Public-safe baseline:
 |  * IMAP: Dovecot on mail.example.com, implicit TLS on port 993.
 |
 */
$config['default_host'] = 'ssl://mail.example.com:993';

/*
 +-----------------------------------------------------------------------+
 | SMTP                                                                   |
 +-----------------------------------------------------------------------+
 |
 | Public-safe baseline:
 |  * SMTP: Postfix submission on mail.example.com with STARTTLS on port 587.
 |
 */
$config['smtp_server'] = 'tls://mail.example.com:587';
$config['smtp_user'] = '%u';
$config['smtp_pass'] = '%p';
$config['smtp_auth_type'] = 'LOGIN';

/*
 +-----------------------------------------------------------------------+
 | Support URL and product name                                           |
 +-----------------------------------------------------------------------+
 */
$config['product_name'] = 'OpenBSD Mailstack Webmail';
$config['support_url'] = '';

/*
 +-----------------------------------------------------------------------+
 | Plugins                                                                |
 +-----------------------------------------------------------------------+
 */
$config['plugins'] = array();

/*
 +-----------------------------------------------------------------------+
 | Skin                                                                   |
 +-----------------------------------------------------------------------+
 */
$config['skin'] = 'elastic';

/*
 +-----------------------------------------------------------------------+
 | Des key placeholder                                                    |
 +-----------------------------------------------------------------------+
 */
$config['des_key'] = '__set_locally__';

/*
 +-----------------------------------------------------------------------+
 | SMTP HELO host                                                         |
 +-----------------------------------------------------------------------+
 |
 | The public-safe example assumes the operator will replace the hostname
 | with a host-local value before deployment.
 |
 */
$config['smtp_helo_host'] = 'mail.example.com';
