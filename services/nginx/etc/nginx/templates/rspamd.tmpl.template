# Rspamd web UI reverse proxy
location /rspamd/ {
    proxy_pass http://__RSPAMD_CONTROLLER_BIND__/;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    # Optional: restrict access to WireGuard subnet only
    allow __WIREGUARD_SUBNET__;
    deny all;

    # Optional: increase buffer size for UI
    proxy_buffering off;
    proxy_read_timeout 300;
}
