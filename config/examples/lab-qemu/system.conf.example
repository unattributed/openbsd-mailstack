OPENBSD_VERSION="7.8"
MAIL_HOSTNAME="mail.example.com"
PRIMARY_DOMAIN="example.com"
ADMIN_EMAIL="ops@example.com"
PUBLIC_IPV4="203.0.113.10"
TIMEZONE="Asia/Bangkok"
TLS_CERT_PATH_FULLCHAIN="/etc/ssl/mail.example.com.fullchain.pem"
TLS_CERT_PATH_KEY="/etc/ssl/private/mail.example.com.key"
POSTFIX_MYHOSTNAME="mail.example.com"
POSTFIX_MYORIGIN="example.com"
POSTFIX_MYDESTINATION="localhost"
POSTFIX_RELAYHOST=""
POSTFIX_VMAIL_BASE="/var/vmail"
POSTFIX_VMAIL_UID="2000"
POSTFIX_VMAIL_GID="2000"
DOVECOT_MAIL_LOCATION="maildir:/var/vmail/%d/%n"
DOVECOT_VMAIL_UID="2000"
DOVECOT_VMAIL_GID="2000"
DOVECOT_FIRST_VALID_UID="2000"
DOVECOT_LAST_VALID_UID="2000"
DOVECOT_LISTEN="127.0.0.1 10.44.0.1"
DOVECOT_AUTH_MECHANISMS="plain login"
RSPAMD_CONTROLLER_PASSWORD_HASH="\$2b\$12\$C6UzMDM.H6dfI/f/IKcEeO6nJb9kL2gS2sOq9YxA2gH0F4Q2Xv4Hi"
RSPAMD_REDIS_HOST="127.0.0.1"
RSPAMD_REDIS_PORT="6379"
RSPAMD_CLAMAV_ENABLED="yes"
RSPAMD_CLAMAV_SOCKET="/var/run/clamav/clamd.sock"
