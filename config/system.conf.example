# config/system.conf.example
#
# Copy this file to config/system.conf and edit it, or let the phase scripts
# prompt for missing values during execution.
#
# Public DNS identity model:
# - one public service hostname used for mail transport and TLS identity
# - one or more hosted mail domains
# - DNS records for all hosted domains point back to the same service hostname
#
# Example:
#   MAIL_HOSTNAME="mail.example.com"
#   PRIMARY_DOMAIN="example.com"
#   DOMAINS="example.com example.net example.org"   # in config/domains.conf
#
# In that model:
# - the certificate is issued for MAIL_HOSTNAME
# - hosted domains publish MX records pointing to MAIL_HOSTNAME
# - DKIM is generated per hosted domain
# - SPF and DMARC are published per hosted domain

OPENBSD_VERSION="7.8"
MAIL_HOSTNAME="mail.example.com"
PRIMARY_DOMAIN="example.com"
ADMIN_EMAIL="ops@example.com"
PUBLIC_IPV4="203.0.113.10"
TIMEZONE="UTC"

TLS_CERT_MODE="single_hostname"
TLS_ACME_PROVIDER="acme-client"
TLS_CERT_FQDN="mail.example.com"
TLS_CERT_PATH_FULLCHAIN="/etc/ssl/mail.example.com.fullchain.pem"
TLS_CERT_PATH_KEY="/etc/ssl/private/mail.example.com.key"

ROUNDCUBE_ENABLED="yes"
ROUNDCUBE_WEB_HOSTNAME="mail.example.com"
POSTFIXADMIN_WEB_HOSTNAME="mail.example.com"
RSPAMD_UI_HOSTNAME="mail.example.com"
