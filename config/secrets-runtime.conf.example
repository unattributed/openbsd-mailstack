# Public-safe host-local secrets runtime layout example
# Copy to an ignored path such as config/local/secrets-runtime.conf or
# /root/.config/openbsd-mailstack/secrets-runtime.conf and edit.

# Directories for host-local runtime secrets.
RUNTIME_SECRET_DIR="/root/.config/openbsd-mailstack/runtime"
RUNTIME_PROVIDER_DIR="/root/.config/openbsd-mailstack/providers"
RUNTIME_DR_DIR="/root/.config/openbsd-mailstack/dr"

# Service credential and secret file locations.
POSTFIXADMIN_DB_ENV_PATH="/root/.config/openbsd-mailstack/runtime/postfixadmin-db.env"
SOGO_DB_ENV_PATH="/root/.config/openbsd-mailstack/runtime/sogo-db.env"
POSTFIXADMIN_SECRETS_PHP_PATH="/etc/postfixadmin/secrets.php"
ROUNDCUBE_SECRETS_INC_PHP_PATH="/etc/roundcube/secrets.inc.php"
VIRUSTOTAL_ENV_PATH="/root/.config/openbsd-mailstack/providers/virustotal.env"
DR_RUNTIME_ENV_PATH="/root/.config/openbsd-mailstack/dr/obsd1.env"
DR_GITHUB_PAT_PATH="/root/.config/openbsd-mailstack/dr/github.pat"

# Ownership and mode expectations.
RUNTIME_SECRET_OWNER="root"
RUNTIME_SECRET_GROUP="wheel"
RUNTIME_SECRET_FILE_MODE="0600"
RUNTIME_SECRET_DIR_MODE="0700"
