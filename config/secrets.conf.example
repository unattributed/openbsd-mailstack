# config/secrets.conf.example
#
# Copy this file to config/secrets.conf.
# Never commit the real secrets.conf file.
#
# Usage notes:
# - Keep the real file private and local to the system where you are building or deploying.
# - Use this file for API keys, database passwords, and external service credentials.
# - Later phases may use these values for DNS automation, alerting, webhook integrations,
#   and malware reputation lookups.
# - Leave values empty until you are ready to populate them.

VULTR_API_KEY=""
BREVO_API_KEY=""
VIRUSTOTAL_API_KEY=""
MYSQL_ROOT_PASSWORD=""
POSTFIXADMIN_DB_PASSWORD=""
ROUNDCUBE_DB_PASSWORD=""
