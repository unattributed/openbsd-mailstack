# config/secrets.conf.example
#
# Copy this file to config/secrets.conf.
# Never commit the real secrets.conf file.
#
# This file stores sensitive values used by later phases and helper scripts.
# Keep the real file private, restrict permissions, and store backups securely.
#
# Usage notes:
# - leave values empty until you are ready to use the matching feature
# - phase scripts should validate required secrets before applying changes
# - do not place quotes inside the values themselves
# - if a secret contains special characters, keep the surrounding double quotes
#
# For multi-domain setups:
# - most API keys remain global, not per-domain
# - SQL passwords are global to this mail host
# - DNS provider credentials may manage multiple zones, one for each hosted domain
#
# Important:
# - create config/secrets.conf from this example
# - chmod the real secrets.conf to 600
# - do not upload the real file to GitHub
#
# Provider and integration examples
VULTR_API_KEY=""
BREVO_API_KEY=""
VIRUSTOTAL_API_KEY=""

# MariaDB and application credentials
MYSQL_ROOT_PASSWORD=""
MAILSTACK_DB_NAME="mailstack"
MAILSTACK_DB_USER="mailstack"
MAILSTACK_DB_PASSWORD=""
POSTFIXADMIN_DB_NAME="postfixadmin"
POSTFIXADMIN_DB_USER="postfixadmin"
POSTFIXADMIN_DB_PASSWORD=""
ROUNDCUBE_DB_NAME="roundcube"
ROUNDCUBE_DB_USER="roundcube"
ROUNDCUBE_DB_PASSWORD=""
