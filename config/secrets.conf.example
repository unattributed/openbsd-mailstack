# config/secrets.conf.example
#
# Copy this file to config/secrets.conf.
# Never commit the real secrets.conf file.
#
# Phase 04 uses the Postfix SQL integration values below.
# Fill them in before running the phase in noninteractive mode, or let the
# phase script prompt for missing values.
#
# Password guidance:
# - use long unique random values
# - do not reuse user mailbox passwords
# - do not store production secrets in Git
# - rotate these values if exposure is suspected

VULTR_API_KEY=""
BREVO_API_KEY=""
VIRUSTOTAL_API_KEY=""
MYSQL_ROOT_PASSWORD="change_this_to_a_long_random_password"
POSTFIXADMIN_DB_NAME="postfixadmin"
POSTFIXADMIN_DB_USER="postfixadmin"
POSTFIXADMIN_DB_PASSWORD="change_this_to_a_long_random_password"
POSTFIXADMIN_SETUP_PASSWORD="change_this_to_a_long_random_password"

POSTFIX_DB_NAME="postfixadmin"
POSTFIX_DB_USER="postfixadmin"
POSTFIX_DB_PASSWORD="change_this_to_a_long_random_password"

ROUNDCUBE_DB_NAME="roundcube"
ROUNDCUBE_DB_USER="roundcube"
ROUNDCUBE_DB_PASSWORD="change_this_to_a_long_random_password"
