# Public-safe security hardening operator inputs
# Copy to an ignored path such as config/local/security.conf or
# /root/.config/openbsd-mailstack/security.conf and edit.

# Broad project baseline for doas.
DOAS_BREAKGLASS_GROUP="wheel"
DOAS_NOPASS_USER="operator"
DOAS_AUTOMATION_OVERLAY_PATH="/etc/doas-automation-local.conf"

# Space-separated command allowlist for the optional command-scoped doas model.
# Tokens may be either a command name, or command:arg1,arg2 for an args-locked rule.
DOAS_TRANSITION_ALLOW_CMDS="true install rcctl pfctl sshd:-t sshd:-T crontab"

# SSH hardening targets used by maint/ssh-hardening-window.ksh.
SSH_PERMIT_ROOT_LOGIN="no"
SSH_PASSWORD_AUTHENTICATION="no"
SSH_KBDINTERACTIVE_AUTHENTICATION="no"
SSH_PUBKEY_AUTHENTICATION="yes"
SSH_MAX_AUTH_TRIES="4"
SSH_MAX_SESSIONS="8"
SSH_CLIENT_ALIVE_INTERVAL="300"
SSH_CLIENT_ALIVE_COUNT_MAX="2"
SSH_LOGIN_GRACE_TIME="30"
SSH_BIND_IPV4=""

# Public-safe authentication posture defaults.
AUTH_PASSWORD_MIN_LENGTH="16"
AUTH_WEB_VPN_ONLY="yes"
AUTH_ADMIN_VPN_ONLY="yes"
AUTH_SECOND_FACTOR_STAGE="plan"
AUTH_ROUNDCUBE_SECOND_FACTOR="evaluate"
AUTH_POSTFIXADMIN_SECOND_FACTOR="evaluate"
