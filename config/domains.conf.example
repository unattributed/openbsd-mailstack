# config/domains.conf.example
#
# Copy this file to config/domains.conf and edit it, or let later phase scripts
# prompt for missing values during execution.
#
# This file controls hosted mail domains and initial mailbox planning.
#
# Multi-domain example:
#   PRIMARY_DOMAIN="example.com"
#   DOMAINS="example.com example.net example.org"
#
# In this example:
# - example.com is the primary administrative domain
# - example.net and example.org are additional hosted mail domains
# - later phases can generate SQL, DKIM, DNS, and mailbox scaffolding for all
#   domains listed in DOMAINS
#
# INITIAL_MAILBOXES is optional. It provides example mailbox addresses that can
# be referenced by later helper tooling or documentation. Separate entries with
# spaces and keep each mailbox within a hosted domain.
#
# DOMAIN_ADMIN_EMAIL is optional. It can be used as a default contact for
# PostfixAdmin setup and future operational notices.

PRIMARY_DOMAIN="example.com"
DOMAINS="example.com example.net example.org"
INITIAL_MAILBOXES="postmaster@example.com abuse@example.com admin@example.net"
DOMAIN_ADMIN_EMAIL="ops@example.com"
