# config/domains.conf.example
PRIMARY_DOMAIN="example.com"
DOMAINS="example.com example.net example.org"
INITIAL_MAILBOXES="postmaster@example.com abuse@example.com admin@example.net"
DOMAIN_ADMIN_EMAIL="ops@example.com"
POSTMASTER_EMAIL="postmaster@example.com"
ABUSE_EMAIL="abuse@example.com"
HOSTMASTER_EMAIL="hostmaster@example.com"
WEBMASTER_EMAIL="webmaster@example.com"
DKIM_SELECTOR="mail"
SPF_POLICY="v=spf1 mx a:mail.example.com -all"
DMARC_POLICY="v=DMARC1; p=quarantine; rua=mailto:dmarc@example.com"
MX_PRIORITY="10"
MTA_STS_MODE="testing"
