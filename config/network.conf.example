# config/network.conf.example
DNS_PROVIDER="vultr"
LAN_INTERFACE="em0"
WAN_INTERFACE="em1"
LAN_IPV4="192.168.1.10"
LAN_CIDR="24"
LAN_SUBNET="192.168.1.0/24"
ENABLE_WIREGUARD="yes"
WIREGUARD_INTERFACE="wg0"
WIREGUARD_ADDRESS="10.44.0.1/24"
WIREGUARD_BIND_IPV4="10.44.0.1"
WIREGUARD_SUBNET="10.44.0.0/24"
WEB_VPN_ONLY="yes"
NGINX_HTTP_BIND="0.0.0.0:80"
NGINX_HTTPS_BINDS="127.0.0.1:443 10.44.0.1:443"
