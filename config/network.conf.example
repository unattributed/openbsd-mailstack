# config/network.conf.example
#
# Copy this file to config/network.conf and edit it, or let later phase scripts
# prompt for missing values during execution.
#
# Public operations baseline:
# - WireGuard used for trusted administrative access
# - operational review paths assume VPN-only admin surfaces
# - service health checks are local-first
#
# Example:
#   ENABLE_WIREGUARD="yes"
#   WIREGUARD_INTERFACE="wg0"
#   WIREGUARD_SUBNET="10.44.0.0/24"
#   WEB_VPN_ONLY="yes"

LAN_INTERFACE="em0"
WAN_INTERFACE="em1"
LAN_IPV4="192.168.1.10"
LAN_CIDR="24"
ENABLE_WIREGUARD="yes"
WIREGUARD_INTERFACE="wg0"
WIREGUARD_SUBNET="10.44.0.0/24"
WEB_VPN_ONLY="yes"
